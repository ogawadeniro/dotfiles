# ------------------------------------------------------------------------------
#  起動時コマンド設定
# ------------------------------------------------------------------------------
command = /bin/zsh
# initial-command = /bin/tmux

# ------------------------------------------------------------------------------
# ウィンドウ設定
# ------------------------------------------------------------------------------
# ウィンドウを最大化して起動(効かない)
# maximize = true

# 起動時のウィンドウサイズ指定
window-width = 231
window-height = 56

# ウィンドウのパディングを設定
window-padding-x = 0
window-padding-y = 0
# window-padding-balance = true

# ウィンドウの装飾
window-decoration = none

# ------------------------------------------------------------------------------
# 色設定
# ------------------------------------------------------------------------------
# 背景を透過
background-opacity = 0.91

# カラーテーマ
# ghostty +list-themes
theme = Catppuccin Mocha

# ------------------------------------------------------------------------------
# フォント設定
# ------------------------------------------------------------------------------
# フォント
font-family = "Bizin Gothic NF, JetBrainsMono Nerd Font Mono"
# フォントサイズ
font-size = 13
# ------------------------------------------------------------------------------
# 操作性設定
# ------------------------------------------------------------------------------
# 入力中はマウスカーソルを隠す
mouse-hide-while-typing = true

# クリップボードの読み書きを許可
clipboard-read = allow
clipboard-write = allow

# ------------------------------------------------------------------------------
# カーソルシェーダ
# ------------------------------------------------------------------------------
custom-shader = shaders/cursor_warp.glsl

# ------------------------------------------------------------------------------
# ghostty操作チートシート
# ------------------------------------------------------------------------------
# ctrl + enter -> フルスクリーン
# ctrl+0 -> フォントサイズリセット
# ctrl-shift-n -> 新ウィンドウ
# ctrl-shift-t -> 新タブ
