{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "plan",
    "agent": {
        "default": {
            "prompt": "日本語で回答およびコード生成をして。常に最新のベストプラクティスを適用して。"
        }
    },
    "permission": {
        "bash": {
            "*": "allow",
            "rm -rf *": "deny",
            "sudo *": "deny"
        }
    }
}
