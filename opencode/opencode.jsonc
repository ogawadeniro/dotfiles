{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "plan",
    "agent": {},
    "permission": {
        "bash": {
            "*": "allow",
            "rm -rf *": "deny",
            "sudo *": "deny"
        },
        "edit": {
            "/tmp/**": "allow",
            "~/work/develop/**": "allow"
        },
        "read": {
            "~/.git_commit_template": "allow"
        }
    },
    "lsp": true
}
