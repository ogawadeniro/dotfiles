{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "plan",
    "agent": {
        "default": {
            "prompt": ""
        }
    },
    "permission": {
        "bash": {
            "*": "allow",
            "rm -rf *": "deny",
            "sudo *": "deny"
        },
        "read": {
            "~/.git_commit_template": "allow"
        }
    }
}
