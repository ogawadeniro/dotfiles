# ==============================================================================
# キーバインド設定
# ==============================================================================
# zsh-vi-modeのバインド読み込み後にキーバインドを設定したいのでここに書く
function zvm_after_init() {
    bindkey -M viins '^r' fzf-select-history
    bindkey '^b' fzf-cdr
    # ctrl-t: fzf ファイル検索
    # alt-c: fzf 選択したディレクトリに移動(zoxidezでいい)
}
